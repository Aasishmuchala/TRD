# God's Eye — Environment Configuration
# Copy to .env and fill in your values
# Used by docker-compose and local development

# ─── Environment ──────────────────────────────────────────
GODS_EYE_ENV=production

# ─── LLM Configuration ───────────────────────────────────
# Provider: openai | nous | custom
GODS_EYE_LLM_PROVIDER=openai

# API key (leave empty to use OAuth device login)
LLM_API_KEY=

# Model to use for agent reasoning
GODS_EYE_MODEL=o4-mini

# Custom inference URL (only for "custom" provider)
LLM_INFERENCE_URL=

# Mock mode: true | false (auto-detected when no API key set)
GODS_EYE_MOCK=false

# ─── Database ─────────────────────────────────────────────
GODS_EYE_DB_PATH=/app/data/gods_eye.db

# ─── Features ─────────────────────────────────────────────
# Auto-learning system (agents learn from simulation results)
GODS_EYE_LEARNING=true

# ─── Network ──────────────────────────────────────────────
# CORS origins (comma-separated, set to your frontend domain in prod)
GODS_EYE_CORS_ORIGINS=http://localhost,http://localhost:80

# Logging level: debug | info | warning | error
GODS_EYE_LOG_LEVEL=info
