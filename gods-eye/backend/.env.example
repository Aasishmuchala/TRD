# God's Eye Backend Configuration
# Copy to .env and fill in values

# Environment: development | staging | production
GODS_EYE_ENV=development

# LLM Provider: openai | nous | custom
GODS_EYE_LLM_PROVIDER=openai

# API key (leave empty to use device auth login)
LLM_API_KEY=

# Model to use
GODS_EYE_MODEL=o4-mini

# Custom inference URL (only for custom provider)
LLM_INFERENCE_URL=

# Mock mode: true | false (auto-detected if no API key)
GODS_EYE_MOCK=false

# Database path
GODS_EYE_DB_PATH=./gods_eye.db

# Learning system
GODS_EYE_LEARNING=true

# CORS origins (comma-separated)
GODS_EYE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging level: debug | info | warning | error
GODS_EYE_LOG_LEVEL=info
